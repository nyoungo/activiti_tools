{
    "name": "activiti-tools",
    "version": "1.0.0",
    "description": "Activiti 6.0.0 工作流维护工具",
    "main": "src/server.js",
    "bin": "src/server.js",
    "scripts": {
        "dev": "node src/server.js",
        "build": "pkg . --targets node18-win-x64 --output build/activiti-tools.exe"
    },
    "dependencies": {
        "express": "^4.18.2",
        "better-sqlite3": "^9.4.3",
        "mysql2": "^3.9.2",
        "pg": "^8.11.3",
        "open": "^10.0.3",
        "cors": "^2.8.5"
    },
    "devDependencies": {
        "pkg": "^5.8.1"
    },
    "pkg": {
        "assets": [
            "src/public/**/*"
        ],
        "targets": [
            "node18-win-x64"
        ],
        "outputPath": "build"
    },
    "author": "",
    "license": "MIT"
}
